===== data/lib/features/orders/mappers/load_details_mapper.dart =====
import 'package:domain/features/orders/entities/load_details_entity.dart';
import '../local/models/load_details_box.dart';
import '../remote/models/load_details_dto.dart';

extension LoadDetailsDtoMapper on LoadDetailsDto {
  LoadDetailsEntity toEntity() {
    return LoadDetailsEntity(remoteId: id);
  }
  LoadDetailsBox toBox() {
    return LoadDetailsBox(remoteId: id);
  }

}

