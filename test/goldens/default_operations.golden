import '../entities/load_details_entity.dart';
import '../repositories/orders_repository.dart';

class LoadDetailsUseCase {
  const LoadDetailsUseCase(this._repository);

  final OrdersRepository _repository;

  Future<LoadDetailsEntity> call() {
    return _repository.loadDetails();
  }
}

