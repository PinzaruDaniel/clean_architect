===== data/lib/features/orders/remote/models/load_details_dto.dart =====
import 'package:freezed_annotation/freezed_annotation.dart';

part 'load_details_dto.freezed.dart';
part 'load_details_dto.g.dart';

@freezed
abstract class LoadDetailsDto with _$LoadDetailsDto {
  const factory LoadDetailsDto({
    required String id,
  }) = _LoadDetailsDto;

  factory LoadDetailsDto.fromJson(Map<String, dynamic> json) =>
      _$LoadDetailsDtoFromJson(json);
}

