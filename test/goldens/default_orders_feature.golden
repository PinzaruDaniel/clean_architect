===== presentation/lib/controllers/orders_controller.dart =====
import 'package:get/get.dart';
import 'package:domain/features/orders/usecases/get_orders_list_use_case.dart';
import 'package:get_it/get_it.dart';

class OrdersController extends GetxController {
  final _getOrdersListUseCase = GetIt.instance.get<GetOrdersListUseCase>();

  final items = <String>[].obs;

  Future<void> load() async {
    final entities = await _getOrdersListUseCase();
    items.assignAll(entities.map((entity) => entity.remoteId));
  }
}

