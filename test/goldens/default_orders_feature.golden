===== data/lib/features/orders/repositories/orders_repository_impl.dart =====
import 'package:domain/features/orders/entities/orders_entity.dart';
import 'package:domain/features/orders/repositories/orders_repository.dart';
import '../mappers/orders_mapper.dart';
import '../local/orders_local_data_source.dart';
import '../remote/orders_remote_data_source.dart';


class OrdersRepositoryImpl implements OrdersRepository {
  const OrdersRepositoryImpl({
    required OrdersRemoteDataSource remoteDataSource,
    required OrdersLocalDataSource localDataSource,
  })  : _remoteDataSource = remoteDataSource,
        _localDataSource = localDataSource;

  final OrdersRemoteDataSource _remoteDataSource;
  final OrdersLocalDataSource _localDataSource;

  @override
  Future<List<OrdersEntity>> getOrdersList() async {
    final items = await _remoteDataSource.getItems();
    await _localDataSource.cacheItems(items);
    return items.map((item) => item.toEntity()).toList(growable: false);
  }
}

